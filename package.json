{
  "name": "booking-system",
  "version": "1.0.0",
  "description": "Movie ticket booking system with authentication",
  "main": "index.mjs",
  "type": "module",
  "scripts": {
    "start": "node index.mjs",
    "dev": "node --watch index.mjs",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:verbose": "NODE_OPTIONS=--experimental-vm-modules jest --verbose",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:auth": "NODE_OPTIONS=--experimental-vm-modules jest tests/auth.test.js",
    "test:booking": "NODE_OPTIONS=--experimental-vm-modules jest tests/booking.test.js",
    "test:all": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand"
  },
  "keywords": [
    "booking",
    "authentication",
    "jwt"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "pg": "^8.10.0"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  }
}